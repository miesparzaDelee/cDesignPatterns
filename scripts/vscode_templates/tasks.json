{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Book",
            "type": "shell",
            "command": "py",
            "args": [
                "-3",
                "scripts/build_book.py"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent", // Don't steal focus, just run
                "panel": "shared"
            }
        },
        {
            "label": "Build Book PDF",
            "type": "shell",
            "command": "typst",
            "args": [
                "compile",
                "--root",
                ".",
                "build/main.typ",
                "build/main.pdf"
            ],
            "dependsOn": [
                "Build Book"
            ],
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "Build Book EPUB",
            "type": "shell",
            "command": "py",
            "args": [
                "-3",
                "scripts/build_epub.py"
            ],
            "dependsOn": [
                "Build Book"
            ],
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "Build Book All",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "py -3 scripts/build_book.py; if ($?) { typst compile --root . build/main.typ build/main.pdf }; if ($?) { py -3 scripts/build_epub.py }"
            ],
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "Test Patterns",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/companion_code/ch3_patterns/build/invoke_wsl_tests.ps1"
            ],
            "options": {
                "cwd": "${workspaceFolder}/companion_code/ch3_patterns"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
